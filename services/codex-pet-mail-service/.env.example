MAIL_SERVICE_TOKEN=replace-with-at-least-32-random-characters
MAIL_CONFIG_ROOT=/var/backend/loulancre
MAIL_CONFIG_PROFILE=dev
# Optional: prefer a dedicated root-owned JSON file with host/port/username/password.
# MAIL_SMTP_CONFIG=/etc/codex-pet-mail-service.smtp.json
MAIL_RATE_DB=/var/lib/codex-pet-mail-service/rate-limit.sqlite3
MAIL_BIND_HOST=127.0.0.1
MAIL_BIND_PORT=8789
MAIL_RECIPIENT_LIMIT=5
MAIL_GLOBAL_LIMIT=200
